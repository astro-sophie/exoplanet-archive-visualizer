   "source": [
    "def user_input_filtering(df):\n",
    "    user_year = int(input(\"Enter a year between 1992 and 2026: \"))\n",
    "    if user_year < 1992 or user_year > 2026:\n",
    "        print(\"Please enter a valid year between 1992 and 2026\")\n",
    "    filtered_df = df[df['disc_year'] <= user_year]\n",
    "    return filtered_df"
   ]
  }
